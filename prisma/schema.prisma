generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  pinHash   String
  email     String   @unique
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id               String      @id @default(cuid())
  uniqueCode       String      @unique
  userId           String?
  user             User?       @relation(fields: [userId], references: [id])
  customerName     String
  phone            String
  email            String
  filmType         String
  format           String
  quantity         Int
  ei               String?
  scanType         String
  process          String
  pushPull         String      @default("0")
  pickupMethod     String
  notes            String?
  status           OrderStatus @default(PENDING)
  editToken        String?     @unique
  editTokenExpires DateTime?
  sheetsRowIndex   Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  SHIPPED
  PROCESSING
  DONE
  EXPIRED
  CANCELLED
}
