generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  pinHash        String
  email          String   @unique
  createdAt      DateTime @default(now())
  orders         Order[]
  profileName    String?
  profilePhone   String?
  profileEmail   String?
  profileAddress String?
}

model Order {
  id               String      @id @default(cuid())
  uniqueCode       String      @unique
  userId           String?
  user             User?       @relation(fields: [userId], references: [id])
  customerName     String
  phone            String
  email            String
  filmItems        Json        @default("[]")
  pickupMethod     String
  deliveryAddress  String?
  notes            String?
  status           OrderStatus @default(PENDING)
  editToken        String?     @unique
  editTokenExpires DateTime?
  sheetsRowIndex   Int?
  trackingNumber   String?
  courierName      String?
  scanFileUrl      String?
  adminNotes       String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model ShopSettings {
  id                  String   @id @default("singleton")
  acceptPushPull      Boolean  @default(true)
  acceptHalfFrame     Boolean  @default(true)
  disabledProcesses   String[] @default([])
  disabledScanTypes   String[] @default([])
  disabledResolutions String[] @default([])
  blockedFilms        String[] @default([])
  filmNotices         Json     @default("{}")
  orderNotice         String?
  pricing             Json     @default("{}")
  adminEmail          String?
  adminPinHash        String?
  updatedAt           DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  SHIPPED
  PROCESSING
  DONE
  EXPIRED
  CANCELLED
}
